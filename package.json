{
  "name": "cursor-skin-manager",
  "version": "0.1.12",
  "description": "A local Windows cursor skin manager built with Tauri, React, TypeScript, and Rust.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Myming15/cursor-skin-manager.git"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "licenses:generate": "node scripts/generate-third-party-licenses.mjs",
    "licenses:check": "node scripts/generate-third-party-licenses.mjs --check",
    "licenses:npm:check": "node scripts/generate-third-party-licenses.mjs --check --ecosystem npm",
    "licenses:cargo:check": "node scripts/generate-third-party-licenses.mjs --check --ecosystem cargo",
    "security:audit": "npm audit --audit-level=high --registry=https://registry.npmjs.org",
    "test:ui": "vitest run",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "lucide-react": "^1.24.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tauri-apps/cli": "^2.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "^25.0.1",
    "prettier": "3.9.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.64.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  }
}
